.article{
    height: 30vh;
    display: flex;
    margin-top: 20vh;

}

.a-left{
    display: flex;
    flex:1;
    position: relative;
    margin-left: 3vw;
    margin-top: 4vh;
    max-width: 35vw;
    min-width: 34vw;
    flex-direction: column;
    text-align: center;

}

.a-left-top>:nth-child(1){
    font-size: 4vw;
    font-weight: bold;
}

.a-left-top>:nth-child(2){
    color: #ff2445;
    font-size: 6vw;
    font-weight: bold;
    margin-top: 100px;
}

.a-left>:nth-child(2) {
    font-size: 2vw;
    margin-left: 4vh;
}
.a-left>:nth-child(3) {
    font-size: 3vw;
    position: center;
    text-align: center;

}

.hire {
    box-shadow: 1px 1px 6px 6px #d56274;
    background: linear-gradient(to top right, #eeac99 0%, #dea1ec 100%);
    color: white;
    font-weight: bold;
    border: none;
    padding: 0px 17px;
    alignment: center;
    text-decoration: none;
    text-align: center;
    font-size: 3vw;
    border-radius: 8px;
    max-height: 6rem;
    min-height: 4rem;
    max-width: 9rem;
    min-width: 6rem;
    margin-left: 5vw;
    margin-top: 4vh;

}

.hire:hover {
    background: linear-gradient(to top right, #f681d6 0%, #eeac99 100%);
    box-shadow: 1px 1px 8px 8px #d56274;
    cursor: pointer;
}

.hire:active {
    background-color: #ff2445;
}

.hire:focus {
    background-color: #ff2445;
    outline: none;
}

.a-right{
    display: flex;
    margin-left: 4vw;
}

.a-right-left{
    background-image: url("../images/Fairy_Melody.png");
    background-size: cover;
    box-shadow: 1px 1px 10px 10px #d6cbd3;
    display: flex;
    flex:1;
    position: relative;
    text-align: center;
    justify-content: center;
    height: 40vh;
    width: 21vw;
    border-radius: 10%;
}

.a-right-left:hover{
    filter: opacity(80%);
    box-shadow: 1px 1px 15px 15px #d6cbd3;
}


.a-right-right{
    flex-direction: column;
    margin-top: 4vh;
    margin-left: 8vw;
    display: flex;
    flex:1;
    position: relative;
    text-align: center;
    justify-content: center;
    height: 40vh;
    width: 20vw;

}
.a-right-right>:nth-child(1) {
    background-color: #ff2445;
    box-shadow: 1px 1px 4px 4px #d6cbd3;
    border-radius: 10%;
    height: 4rem;
    width: 18rem;
    color: white;
    margin-top: 2vh;
    font-size: 3vw;
}

.a-right-right>:nth-child(1):hover{
    filter: opacity(80%);
    box-shadow: 1px 1px 10px 10px #d6cbd3;
}

.a-right-right>:nth-child(2) {
    background-color: #eeac99;
    box-shadow: 1px 1px 4px 4px #d6cbd3;
    border-radius: 10%;
    height: 4rem;
    width: 18rem;
    color: white;
    margin-top: 2vh;
    font-size: 3vw;
}

.a-right-right>:nth-child(2):hover{
    filter: opacity(80%);
    box-shadow: 1px 1px 10px 10px #d6cbd3;
}

.a-right-right>:nth-child(3) {
    box-shadow: 1px 1px 5px 5px #eeac99;
    background-color: #d6cbd3;
    border-radius: 10%;
    height: 3rem;
    width: 18rem;
    color: white;
    margin-top: 2vh;
    font-size: 2vw;
    margin-bottom: 6vh;
}

.a-right-right>:nth-child(3):hover{
    filter: opacity(80%);
    box-shadow: 1px 1px 10px 10px #eeac99;
}
